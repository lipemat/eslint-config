{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "declaration": false,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2024",
    "verbatimModuleSyntax": false
  },
  "include": [
    "./index.ts",
    "jest/**/*.ts",
    "jest/**/*.tsx",
    "jest/**/*.svelte",
    "plugins/**/*.ts"
  ]
}
